{
        // "output": "DP-3",
        "layer": "top",
        "position": "top",
        "reload_style_on_change": true,
        "modules-left": ["hyprland/workspaces"],
        "modules-center": ["clock"],
        "modules-right": [
            "group/expand",
            "tray",
            "custom/polycat",
            "memory",
            "custom/gpu",
            "custom/cliphist",
            "custom/hdr_brightness",
            "custom/hdr_saturation",
            "pulseaudio",
            "bluetooth",
            "network",
            "custom/pacman",
            "custom/notification"
        ],
        "custom/gpu": {
            "format": "{icon} {text}",
            "exec": "gpu-usage-waybar",
            "return-type": "json",
            "format-icons": "󰾲",
            "on-click": "kitty nvtop"
        },
        "custom/hdr_brightness": {
            "exec": "~/scripts/hdr_control.sh brightness get",
            "interval": "once",
            "signal": 10,
            "on-scroll-up": "~/scripts/hdr_control.sh brightness up && pkill -RTMIN+10 waybar",
            "on-scroll-down": "~/scripts/hdr_control.sh brightness down && pkill -RTMIN+10 waybar",
            "format": "󰖨 {}",
            "tooltip": true,
            "tooltip-format": "brightness"
        },

        "custom/hdr_saturation": {
            "exec": "~/scripts/hdr_control.sh saturation get",
            "interval": "once",
            "signal": 11,
            "on-scroll-up": "~/scripts/hdr_control.sh saturation up && pkill -RTMIN+11 waybar",
            "on-scroll-down": "~/scripts/hdr_control.sh saturation down && pkill -RTMIN+11 waybar",
            "format": "{}",
            "tooltip": true,
            "tooltip-format": "saturation"
        },
        "pulseaudio": {
            "format": "{icon} {volume}%",
            "format-muted": "",
            "format-icons": {
                "default": ["", ""]
            },
            "on-click": "pavucontrol" // Opens GUI mixer
        },
        "custom/cliphist": {
            "format": "󰅍 {}",
            "max-length": 15,
            "interval": 1,
            "exec": "cliphist list | head -n 1 | cut -f 2-",
            "on-click": "sh -c '~/.config/wofi/scripts/cliphist-wofi-img | wl-copy'",
            "on-click-right": "cliphist wipe",
            "escape": true,
            "tooltip": false
        },
        "custom/polycat": {
            "format": "{}",
            "exec": "polycat",
            "on-click": "kitty htop -s PERCENT_CPU",
            "tooltip": false
        },
        "hyprland/workspaces": {
            "format": "{icon}",
            "format-icons": {
                "active": "",
                "default": "",
                "empty": ""
            },
            "persistent-workspaces": {
                "*": [ 1,2,3,4,5 ]
            }
        },
        "custom/notification": {
            "tooltip": false,
            "format": "",
            "on-click": "swaync-client -t -sw",
            "escape": true
        },
        "clock": {
            "format": "{:%b %e %a  %I:%M %p} ",
            "interval": 10,
            "tooltip-format": "<tt>{calendar}</tt>",
            "calendar": {
                "format": {
                    "today": "<span color='#fAfBfC'><b>{}</b></span>"
                }
            },
            "actions": {
                "on-click-right": "shift_down",
                "on-click": "shift_up"
            }
        },
        "network": {
            "format-wifi": "",
            "format-ethernet":"",
            "format-disconnected": "",
            "tooltip-format-disconnected": "Error",
            "tooltip-format-wifi": "{essid} ({signalStrength}%) ",
            "tooltip-format-ethernet": "{ifname} 🖧 ",
            "on-click": "nm-connection-editor"
        },
        "bluetooth": {
            "format-on": "󰂯",
            "format-off": "BT-off",
            "format-disabled": "󰂲",
            "format-connected-battery": "{device_battery_percentage}% 󰂯",
            "format-alt": "{device_alias} 󰂯",
            "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
            "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
            "tooltip-format-enumerate-connected": "{device_alias}\n{device_address}",
            "tooltip-format-enumerate-connected-battery": "{device_alias}\n{device_address}\n{device_battery_percentage}%",
            "on-click-right": "blueman-manager"
        },
        "battery": {
            "interval":30,
            "states": {
                "good": 95,
                "warning": 30,
                "critical": 20
            },
            "format": "{capacity}% {icon}",
            "format-charging": "{capacity}% 󰂄",
            "format-plugged": "{capacity}% 󰂄 ",
            "format-alt": "{time} {icon}",
            "format-icons": [
                "󰁻",
            "󰁼",
            "󰁾",
            "󰂀",
            "󰂂",
            "󰁹"
            ]
        },
        "custom/pacman": {
            "format": "󰅢 {}",
            "interval": 300,
            "exec": "checkupdates | wc -l",
            "exec-if": "exit 0",
            "on-click": "kitty sh -c 'yay -Syu; echo Done - Press enter to exit; read'; pkill -SIGRTMIN+8 waybar",
            "signal": 8,
            "tooltip": false
        },
        "custom/expand": {
            "format": "",
            "tooltip": false
        },
        "custom/endpoint":{
            "format": "|",
            "tooltip": false
        },
        "group/expand": {
            "orientation": "horizontal",
            "drawer": {
                "transition-duration": 600,
                "transition-to-left": true,
                "click-to-reveal": true
            },
            "modules": ["custom/expand", "custom/colorpicker", "custom/endpoint"]
        },
        "custom/colorpicker": {
            "format": "{}",
            "return-type": "json",
            "interval": "once",
            "exec": "~/.config/waybar/scripts/colorpicker.sh -j",
            "on-click": "~/.config/waybar/scripts/colorpicker.sh",
            "signal": 1
        },
        "memory": {
            "format": " {used:0.1f}G",
            "on-click": "kitty htop -s PERCENT_MEM",
            "tooltip-format": "{used:0.1f}G / {total:0.1f}G"
        },
        "temperature": {
            "critical-threshold": 80,
            "format": ""
        },
        "tray": {
            "icon-size": 14,
            "spacing": 10
        }
}

